{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-bcmath": "*",
        "alibabacloud/dysmsapi-20170525": "^4.2",
        "alibabacloud/ocr-api-20210707": "^3.1.3",
        "alibabacloud/tea-utils": "^0.2.21",
        "guzzlehttp/guzzle": "^7.10",
        "laravel-lang/common": "^6.8",
        "laravel/framework": "^13.0",
        "laravel/reverb": "^1.10",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.29",
        "php-mqtt/laravel-client": "^1.8",
        "phpoffice/phpspreadsheet": "^5.1",
        "phpoffice/phpword": "^1.4",
        "spatie/laravel-permission": "^6.25",
        "symfony/dom-crawler": "^7.3.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "php artisan serve",
            "php artisan queue:listen --tries=1 --timeout=0"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [],
        "post-install-cmd": [],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "hooks": {
            "pre-commit": [
                "echo \"Committing as $(git config user.name)\"",
                "bin_dir=$(composer -q global config bin-dir --absolute)",
                "files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\\.php$')",
                "if [ -n \"$files\" ]; then",
                "  \"$bin_dir/php-cs-fixer\" fix --diff --config=./.php-cs-fixer.php $files && git add $files",
                "fi"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "github-protocols": ["ssh"]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
